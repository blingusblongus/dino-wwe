---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import BlogCard from "../components/BlogCard.astro";
import DinoCard from "../components/DinoCard.astro";
import { roster } from "../data/roster";

const posts = (await getCollection("blog"))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);
---

<Layout title="Home">
  <section class="mb-12 text-center">
    <h1 class="text-4xl font-bold text-gold tracking-wide mb-2">WDAA</h1>
    <p class="text-muted text-lg">World Dinosaur Athletic Association</p>
    <p class="text-sm text-muted mt-1">Attitude Era. Four dinos. One belt.</p>
    <a
      href="/shows/ep1"
      class="inline-block mt-6 px-6 py-2.5 bg-gold text-bg font-bold rounded hover:opacity-90 transition-opacity"
    >
      Watch Live
    </a>
  </section>

  <section class="mb-12">
    <div class="flex items-baseline justify-between mb-4">
      <h2 class="text-xl font-bold text-gold">The Asteroid Report</h2>
      <a href="/blog" class="text-muted text-sm hover:text-gold">All posts &rarr;</a>
    </div>
    <div class="grid gap-4 md:grid-cols-3">
      {posts.map((post) => (
        <BlogCard
          slug={post.id}
          title={post.data.title}
          date={post.data.date}
          author={post.data.author}
          summary={post.data.summary}
          tags={post.data.tags}
        />
      ))}
    </div>
  </section>

  <section>
    <div class="flex items-baseline justify-between mb-4">
      <h2 class="text-xl font-bold text-gold">Active Roster</h2>
      <a href="/roster" class="text-muted text-sm hover:text-gold">Full roster &rarr;</a>
    </div>
    <div class="grid gap-4 md:grid-cols-2">
      {roster.map((dino) => <DinoCard dino={dino} />)}
    </div>
  </section>
</Layout>
